# Microsoft MCP Configuration Template
# Copy this to .env and fill in your values from Azure Portal

# ==============================================================================
# REQUIRED: Azure Application Credentials
# Get these from Azure Portal → App Registrations → Your App
# ==============================================================================

# Your Azure Application (Client) ID
# Found in: Azure Portal → App Registrations → [Your App] → Overview
MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Your Azure Directory (Tenant) ID
# Found in: Azure Portal → App Registrations → [Your App] → Overview
MICROSOFT_TENANT_ID=00000000-0000-0000-0000-000000000000

# Your Client Secret (KEEP SECRET! ⚠️)
# Found in: Azure Portal → App Registrations → [Your App] → Certificates & Secrets
# ⚠️ IMPORTANT: 
#   - Save this securely
#   - Never commit to version control
#   - Keep it confidential
MICROSOFT_CLIENT_SECRET=your_client_secret_here_keep_secure

# ==============================================================================
# OPTIONAL: Server Configuration
# ==============================================================================

# MCP Server Port (if using HTTP transport)
# Default: 8000
MCP_PORT=8000

# Server Host
# Default: localhost
MCP_HOST=localhost

# Enable Debug Logging
# Default: false
DEBUG=false

# ==============================================================================
# Quick Setup Steps:
# ==============================================================================
# 1. Go to https://portal.azure.com
# 2. Create new App Registration
# 3. Copy Client ID and Tenant ID above
# 4. Create Client Secret (Certificates & Secrets)
# 5. Add API Permissions (Mail.*, Calendars.*, Files.*)
# 6. Grant Admin Consent
# 7. Run: python microsoft_mcp.py
# ==============================================================================
